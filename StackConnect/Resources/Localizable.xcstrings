    "You hit Apple's rate limit. Wait a moment and try again.": {
      "comment": "Error message displayed when a request is rate-limited by Apple.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben das Anfragelimit von Apple erreicht. Warten Sie einen Moment und versuchen Sie es erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has alcanzado el límite de solicitudes de Apple. Espera un momento e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez atteint la limite de requêtes d'Apple. Patientez un instant et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai raggiunto il limite di richieste di Apple. Attendi un momento e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple のレート制限に達しました。しばらく待ってから再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple의 요청 한도에 도달했습니다. 잠시 후 다시 시도해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je hebt de aanvraaglimiet van Apple bereikt. Wacht even en probeer het opnieuw."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você atingiu o limite de requisições da Apple. Aguarde um momento e tente novamente."
          }
        }
      }
    },
