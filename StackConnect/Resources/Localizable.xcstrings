    "Expiring a build immediately prevents testers from installing it. This cannot be undone via the API.": {
      "comment": "A footer text in the \"Actions\" section of the build detail view, explaining that expiring a build cannot be undone.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie einen Build ablaufen lassen, können Tester ihn sofort nicht mehr installieren. Dies kann über die API nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Caducar un build impide de inmediato que los testers lo instalen. Esto no se puede deshacer a través de la API."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faire expirer un build empêche immédiatement les testeurs de l’installer. Cette action est irréversible via l’API."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Far scadere un build impedisce immediatamente ai tester di installarlo. Questa operazione non può essere annullata tramite l’API."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビルドを失効させると、テスターはすぐにインストールできなくなります。これはAPIから元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빌드를 만료하면 테스터가 즉시 설치할 수 없게 됩니다. 이 작업은 API로 취소할 수 없습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als je een build laat vervallen, kunnen testers deze direct niet meer installeren. Dit kan niet ongedaan worden gemaakt via de API."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Expirar um build impede imediatamente que os testadores o instalem. Isso não pode ser desfeito pela API."
          }
        }
      }
    },
