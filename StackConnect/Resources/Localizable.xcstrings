          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple はセキュリティ上の理由でこの変更を拒否しました。この操作は developer.apple.com でのみ利用できる場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple가 보안상의 이유로 이 변경을 거부했습니다. 이 작업은 developer.apple.com에서만 가능할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
