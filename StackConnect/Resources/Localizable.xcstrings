    "Use at least %lld characters. Tip: tap \"Generate strong password\" for a secure one.": {
      "comment": "A warning message displayed in the password section of the export account view, explaining that the password is too weak. The argument is the minimum number of characters required in the password.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
