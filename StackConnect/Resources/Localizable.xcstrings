    "Expired builds cannot be installed by testers. This action cannot be undone via the API — only Apple support can restore an expired build.": {
      "comment": "A message that appears when an alert is presented to confirm expiring a build.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abgelaufene Builds können nicht von Testern installiert werden. Diese Aktion kann über die API nicht rückgängig gemacht werden – nur der Apple-Support kann einen abgelaufenen Build wiederherstellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los testers no pueden instalar builds caducados. Esta acción no se puede deshacer a través de la API: solo el soporte de Apple puede restaurar un build caducado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les testeurs ne peuvent pas installer les builds expirés. Cette action est irréversible via l’API ; seul le support Apple peut restaurer un build expiré."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I build scaduti non possono essere installati dai tester. Questa azione non può essere annullata tramite l’API: solo l’assistenza Apple può ripristinare un build scaduto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "期限切れのビルドはテスターがインストールできません。この操作はAPIから元に戻せません。期限切れのビルドを復元できるのはAppleサポートのみです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "만료된 빌드는 테스터가 설치할 수 없습니다. 이 작업은 API로 취소할 수 없으며, 만료된 빌드는 Apple 지원팀만 복원할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vervallen builds kunnen niet door testers worden geïnstalleerd. Deze actie kan niet ongedaan worden gemaakt via de API — alleen Apple-support kan een vervallen build herstellen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Builds expirados não podem ser instalados pelos testadores. Esta ação não pode ser desfeita pela API — somente o suporte da Apple pode restaurar um build expirado."
          }
        }
      }
    },
    "Expired or invalid profiles can only be deleted.": {
      "comment": "A footer message explaining that expired or invalid profiles can only be deleted.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abgelaufene oder ungültige Profile können nur gelöscht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los perfiles caducados o no válidos solo se pueden eliminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les profils expirés ou non valides ne peuvent être que supprimés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I profili scaduti o non validi possono solo essere eliminati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "期限切れまたは無効なプロファイルは削除のみ可能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "만료되었거나 유효하지 않은 프로파일은 삭제만 할 수 있습니다."
          }
        },
        "nl": {
