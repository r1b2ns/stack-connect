    "Apple doesn't accept this name. Try a shorter or simpler value, without special characters.": {
      "comment": "Error message when an entity's name is invalid.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple akzeptiert diesen Namen nicht. Versuchen Sie es mit einem kürzeren oder einfacheren Wert ohne Sonderzeichen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple no acepta este nombre. Prueba con un valor más corto o sencillo, sin caracteres especiales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple n'accepte pas ce nom. Essayez une valeur plus courte ou plus simple, sans caractères spéciaux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple non accetta questo nome. Prova un valore più breve o più semplice, senza caratteri speciali."
