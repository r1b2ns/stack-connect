    "Condition values override the default when the condition is matched.": {
      "comment": "A footer label explaining that condition values override the default when the condition is matched.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedingungswerte überschreiben den Standardwert, wenn die Bedingung erfüllt ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los valores de condición anulan el valor predeterminado cuando se cumple la condición."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "new",
            "value": ""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les valeurs de condition remplacent la valeur par défaut lorsque la condition est remplie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I valori della condizione sostituiscono il valore predefinito quando la condizione è soddisfatta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "条件が一致すると、条件の値がデフォルト値を上書きします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "조건이 일치하면 조건 값이 기본값을 재정의합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voorwaardewaarden overschrijven de standaardwaarde wanneer aan de voorwaarde wordt voldaan."
          }
        },
