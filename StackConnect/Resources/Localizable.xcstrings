    "Apple refused this change for security reasons.": {
      "comment": "Error message displayed when an API request is rejected by Apple for security reasons.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple hat diese Änderung aus Sicherheitsgründen abgelehnt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple rechazó este cambio por motivos de seguridad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple a refusé cette modification pour des raisons de sécurité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple ha rifiutato questa modifica per motivi di sicurezza."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple はセキュリティ上の理由でこの変更を拒否しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple가 보안상의 이유로 이 변경을 거부했습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple heeft deze wijziging om veiligheidsredenen geweigerd."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A Apple recusou esta alteração por motivos de segurança."
          }
        }
      }
    },
    "Apple refused this change for security reasons. The operation may only be available on developer.apple.com.": {
      "comment": "User-facing message when Apple refuses a change for security reasons, and the operation is only available on developer.apple.com.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple hat diese Änderung aus Sicherheitsgründen abgelehnt. Der Vorgang ist möglicherweise nur auf developer.apple.com verfügbar."
          }
        },
        "es": {
          "stringUnit": {
