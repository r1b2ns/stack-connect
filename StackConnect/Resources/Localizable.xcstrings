    "On the iPhone or iPad open Safari and go to a UDID provider you trust (e.g. udid.tech, get.udid.io)": {
      "comment": "Step in the \"How to find the UDID\" section of the create device sheet, describing how to find the UDID on an iPhone or iPad using Safari and a trusted UDID provider.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne auf dem iPhone oder iPad Safari und gehe zu einem UDID-Anbieter, dem du vertraust (z. B. udid.tech, get.udid.io)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En el iPhone o iPad, abre Safari y ve a un proveedor de UDID en el que confíes (p. ej., udid.tech, get.udid.io)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sur l'iPhone ou l'iPad, ouvrez Safari et accédez à un fournisseur d'UDID de confiance (par ex. udid.tech, get.udid.io)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sull'iPhone o iPad apri Safari e vai a un provider di UDID di cui ti fidi (ad es. udid.tech, get.udid.io)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone または iPad で Safari を開き、信頼できる UDID プロバイダ（例: udid.tech、get.udid.io）にアクセスします"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone 또는 iPad에서 Safari를 열고 신뢰할 수 있는 UDID 제공업체(예: udid.tech, get.udid.io)로 이동합니다"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open op de iPhone of iPad Safari en ga naar een UDID-provider die je vertrouwt (bijv. udid.tech, get.udid.io)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "No iPhone ou iPad, abra o Safari e acesse um provedor de UDID confiável (por exemplo, udid.tech, get.udid.io)"
          }
        }
      }
    },
