    "The account \"%@\" has expired. Re-import its file to keep using it, or it will stay locked.": {
      "comment": "A message shown in an alert when an account has expired. The argument is the name of the account that has expired.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Account „%@“ ist abgelaufen. Importiere die zugehörige Datei erneut, um ihn weiter zu verwenden, sonst bleibt er gesperrt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cuenta \"%@\" ha caducado. Vuelve a importar su archivo para seguir usándola, o permanecerá bloqueada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le compte « %@ » a expiré. Réimportez son fichier pour continuer à l'utiliser, sinon il restera verrouillé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'account \"%@\" è scaduto. Reimporta il suo file per continuare a usarlo, altrimenti rimarrà bloccato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウント「%@」の有効期限が切れました。引き続き使用するにはファイルを再インポートしてください。そうしないとロックされたままになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 \"%@\"이(가) 만료되었습니다. 계속 사용하려면 파일을 다시 가져오세요. 그렇지 않으면 잠긴 상태로 유지됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het account \"%@\" is verlopen. Importeer het bestand opnieuw om het te blijven gebruiken, anders blijft het vergrendeld."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A conta \"%@\" expirou. Importe o arquivo novamente para continuar usando-a, ou ela permanecerá bloqueada."
          }
        }
      }
    },
    "The account \"%@\" has expired. Re-import its file to keep using it.": {
      "comment": "An alert message that appears when a user's access to a medication account expires. The placeholder inside the double quotes should be replaced with the name of the account.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Account „%@“ ist abgelaufen. Importiere die zugehörige Datei erneut, um ihn weiter zu verwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cuenta \"%@\" ha caducado. Vuelve a importar su archivo para seguir usándola."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le compte « %@ » a expiré. Réimportez son fichier pour continuer à l'utiliser."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'account \"%@\" è scaduto. Reimporta il suo file per continuare a usarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウント「%@」の有効期限が切れました。引き続き使用するにはファイルを再インポートしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 \"%@\"이(가) 만료되었습니다. 계속 사용하려면 파일을 다시 가져오세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het account \"%@\" is verlopen. Importeer het bestand opnieuw om het te blijven gebruiken."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A conta \"%@\" expirou. Importe o arquivo novamente para continuar usando-a."
          }
        }
      }
    },
    "The account \"%@\" was exported successfully. Share the encrypted file with your team.": {
      "comment": "A message that appears in a feedback screen after a user successfully exports an account. The argument is the name of the account that was successfully exported.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Account „%@“ wurde erfolgreich exportiert. Teile die verschlüsselte Datei mit deinem Team."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cuenta \"%@\" se exportó correctamente. Comparte el archivo cifrado con tu equipo."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "new",
            "value": ""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le compte « %@ » a été exporté avec succès. Partagez le fichier chiffré avec votre équipe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'account \"%@\" è stato esportato correttamente. Condividi il file crittografato con il tuo team."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウント「%@」を正常にエクスポートしました。暗号化されたファイルをチームと共有してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정 \"%@\"을(를) 성공적으로 내보냈습니다. 암호화된 파일을 팀과 공유하세요."
          }
        },
        "nl": {
