    "Analytics reports are being generated. This usually takes 24-48 hours after the first request. Please check back later.": {
      "comment": "Error message indicating that analytics reports are being generated and that the user should try again later.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Analytics-Berichte werden erstellt. Dies dauert nach der ersten Anfrage normalerweise 24–48 Stunden. Bitte schaue später noch einmal vorbei."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se están generando los informes de analíticas. Esto suele tardar entre 24 y 48 horas tras la primera solicitud. Vuelve a comprobarlo más tarde."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "new",
            "value": ""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les rapports Analytics sont en cours de génération. Cela prend généralement 24 à 48 heures après la première demande. Veuillez réessayer plus tard."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I report di Analytics sono in fase di generazione. Di solito ci vogliono 24-48 ore dopo la prima richiesta. Riprova più tardi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Analytics レポートを生成しています。通常、最初のリクエストから24～48時間かかります。後でもう一度ご確認ください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "분석 보고서를 생성하고 있습니다. 첫 요청 후 보통 24~48시간이 걸립니다. 나중에 다시 확인해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Analytics-rapporten worden gegenereerd. Dit duurt na het eerste verzoek meestal 24-48 uur. Kom later terug."
          }
        },
        "pt-BR": {
