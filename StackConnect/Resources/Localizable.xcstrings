    "Expire build %@? Testers will no longer be able to install it. This cannot be undone via the API.": {
      "comment": "A confirmation alert message that asks the user to confirm expiring a build. The placeholder text inside the parentheses is replaced with the build's version number.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Build %@ ablaufen lassen? Tester können ihn dann nicht mehr installieren. Dies kann über die API nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Caducar el build %@? Los testers ya no podrán instalarlo. Esto no se puede deshacer a través de la API."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faire expirer le build %@ ? Les testeurs ne pourront plus l’installer. Cette action est irréversible via l’API."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Far scadere il build %@? I tester non potranno più installarlo. Questa operazione non può essere annullata tramite l’API."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビルド %@ を失効させますか？テスターはインストールできなくなります。これはAPIから元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빌드 %@을(를) 만료하시겠습니까? 테스터가 더 이상 설치할 수 없습니다. 이 작업은 API로 취소할 수 없습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Build %@ laten vervallen? Testers kunnen deze dan niet meer installeren. Dit kan niet ongedaan worden gemaakt via de API."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Expirar o build %@? Os testadores não poderão mais instalá-lo. Isso não pode ser desfeito pela API."
          }
        }
      }
    },
