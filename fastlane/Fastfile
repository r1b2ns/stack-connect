# Fastfile — StackConnect iOS
#
# Usage (from repo root):
#   bundle exec fastlane test
#   bundle exec fastlane beta_dev
#   bundle exec fastlane beta
#   bundle exec fastlane beta_all      # uploads both dev and prod betas in one run
#   bundle exec fastlane screenshots
#   bundle exec fastlane metadata
#   bundle exec fastlane release
#
# Required environment variables for beta* / release lanes (set in fastlane/.env):
#   APP_STORE_CONNECT_API_KEY_ID      \
#   APP_STORE_CONNECT_API_ISSUER_ID    > App Store Connect API key — no Apple ID
#   APP_STORE_CONNECT_API_KEY_CONTENT /   password prompt required

default_platform(:ios)

# ─── Project constants ────────────────────────────────────────────────────────

PROJECT              = "StackConnect.xcodeproj"
SCHEME_DEV           = "StackConnect Development"
SCHEME_PROD          = "StackConnect Production"
BUNDLE_ID            = ENV["BUNDLE_ID"]
BUNDLE_ID_DEV        = ENV["BUNDLE_ID_DEV"]
OUTPUT_DIR           = "build"

# ─── Platform ────────────────────────────────────────────────────────────────

platform :ios do

  # ── before_all ─────────────────────────────────────────────────────────────

  before_all do
    # Ensure Ruby and sub-processes use UTF-8 so Xcode log parsing never
    # raises "invalid byte sequence in US-ASCII".
    ENV["LANG"]   = "en_US.UTF-8"
    ENV["LC_ALL"] = "en_US.UTF-8"

    # Regenerate the Xcode project from project.yml so the workspace is always
    # up-to-date before building, regardless of untracked source-file changes.
    sh("cd .. && xcodegen generate --spec project.yml")

    # Authenticate with App Store Connect via API key (no password prompt).
    # Values are loaded automatically from fastlane/.env.
    if ENV["APP_STORE_CONNECT_API_KEY_ID"]
      app_store_connect_api_key(
        key_id:                ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id:             ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_content:           ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
        is_key_content_base64: true,
        in_house:              false
      )
    end
  end

  # ── test ───────────────────────────────────────────────────────────────────

  desc "Run unit tests on the simulator.\n\n    Usage:\n      bundle exec fastlane test"
  lane :test do
    run_tests(
      project:             PROJECT,
      scheme:              SCHEME_DEV,
      device:              "iPhone 16 Pro",
      clean:               true,
      result_bundle:       true,
      output_directory:    "#{OUTPUT_DIR}/test_output",
      output_files:        "report.junit"
    )
  end

  # ── beta_dev ────────────────────────────────────────────────────────────────

  desc "Build and upload a new Development beta to TestFlight.\n\n    Usage:\n      bundle exec fastlane beta_dev"
  lane :beta_dev do
    increment_build_number(xcodeproj: PROJECT)

    match(type: "appstore", app_identifier: [BUNDLE_ID_DEV], readonly: false)

    build_app(
      project:          PROJECT,
      scheme:           SCHEME_DEV,
      configuration:    "Debug",
      output_directory: OUTPUT_DIR,
      output_name:      "StackConnect-Dev.ipa",
      export_method:    "app-store",
      xcargs:           "CODE_SIGN_STYLE=Manual",
      export_options: {
        signingStyle:         "manual",
        provisioningProfiles: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
      },
      clean:            true
    )

    upload_to_testflight(
      app_identifier:                    BUNDLE_ID_DEV,
      skip_waiting_for_build_processing: true
    )
  end

  # ── beta ───────────────────────────────────────────────────────────────────

  desc "Build and upload a new beta to TestFlight.\n\n    Usage:\n      bundle exec fastlane beta"
  lane :beta do
    increment_build_number(xcodeproj: PROJECT)

    match(type: "appstore", app_identifier: [BUNDLE_ID], readonly: false)

    build_app(
      project:          PROJECT,
      scheme:           SCHEME_PROD,
      configuration:    "Release",
      output_directory: OUTPUT_DIR,
      output_name:      "StackConnect.ipa",
      export_method:    "app-store",
      xcargs:           "CODE_SIGN_STYLE=Manual",
      export_options: {
        signingStyle:         "manual",
        provisioningProfiles: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
      },
      clean:            true
    )

    upload_to_testflight(
      app_identifier:                    BUNDLE_ID,
      skip_waiting_for_build_processing: true
    )
  end

  # ── beta_all ────────────────────────────────────────────────────────────────

  desc "Build and upload both Dev and Production betas to TestFlight in a single run.\n\n    Usage:\n      bundle exec fastlane beta_all"
  lane :beta_all do
    beta_dev
    beta
  end

  # ── screenshots ─────────────────────────────────────────────────────────────

  desc "Upload App Store screenshots without building.\n\n    Usage:\n      bundle exec fastlane screenshots"
  lane :screenshots do
    upload_to_app_store(
      app_identifier:             BUNDLE_ID,
      force:                      true,   # skip HTML report preview
      skip_binary_upload:         true,
      skip_screenshots:           false,
      skip_metadata:              true,
      run_precheck_before_submit: false
    )
  end

  # ── metadata ────────────────────────────────────────────────────────────────

  desc "Upload App Store metadata (description, keywords, URLs) without building.\n\n    Usage:\n      bundle exec fastlane metadata"
  lane :metadata do
    upload_to_app_store(
      app_identifier:             BUNDLE_ID,
      force:                      true,   # skip HTML report preview
      skip_binary_upload:         true,
      skip_screenshots:           true,
      skip_metadata:              false,
      run_precheck_before_submit: false   # skip URL reachability checks
    )
  end

  # ── release ────────────────────────────────────────────────────────────────

  desc "Build and submit a new version to the App Store.\n\n    Usage:\n      bundle exec fastlane release"
  lane :release do
    increment_build_number(xcodeproj: PROJECT)

    match(type: "appstore", app_identifier: [BUNDLE_ID], readonly: false)

    build_app(
      project:          PROJECT,
      scheme:           SCHEME_PROD,
      configuration:    "Release",
      output_directory: OUTPUT_DIR,
      output_name:      "StackConnect.ipa",
      export_method:    "app-store",
      xcargs:           "CODE_SIGN_STYLE=Manual",
      export_options: {
        signingStyle:         "manual",
        provisioningProfiles: lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
      },
      clean:            true
    )

    upload_to_app_store(
      app_identifier:             BUNDLE_ID,
      submit_for_review:          false,
      automatic_release:          false,
      force:                      true,   # skip HTML report preview
      skip_screenshots:           true,
      skip_metadata:              false,  # metadata/en-US/* is uploaded alongside the binary
      run_precheck_before_submit: false   # skip URL reachability checks
    )
  end

  # ── after_all / error ──────────────────────────────────────────────────────

  after_all do |lane|
    UI.success("Lane '#{lane}' completed successfully.")
  end

  error do |lane, exception|
    UI.error("Lane '#{lane}' failed: #{exception.message}")
  end

end
